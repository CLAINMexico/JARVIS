{
  "app": {
    "name": "MyApp",
    "description": "Lorem ipsum dolor sit amet consectetur adipiscing elit, sem himenaeos ad nisi at odio ante, sagittis curae torquent fames tellus venenatis.",
    "version": "0.0.0",
    "environment": "local",
    "license": "SETTINGS_LICENSE_KEY",
    "timeZone": "America/Mexico_City"
  },
  "server": {
    "host": "localhost",
    "port": 3000
  },
  "api": {
    "version": "v1",
    "cors": {
      "enabled": true,
      "origins": [
        "http://localhost:5173",
        "http://localhost:3000"
      ]
    },
    "jwt": {
      "enabled": true,
      "secret": "SETTINGS_SECURITY_JWT_SECRET",
      "accessTokenExpiresIn": "15m",
      "refreshTokenExpiresIn": "7d"
    }
  },
  "modules": {
    "logger": {
      "enabled": true,
      "level": "debug",
      "console": {
        "enabled": true,
        "colors": true
      },
      "file": {
        "enabled": true,
        "path": "./logs",
        "splitByLevel": true,
        "writeAll": true
      }
    },
    "database": {
      "enabled": true,
      "defaultConnection": "mssql",
      "connections": {
        "mssql": {
          "driver": "mssql",
          "host": "localhost",
          "port": 1433,
          "database": "SETTINGS_DATABASE_NAME",
          "username": "SETTINGS_DATABASE_USERNAME",
          "password": "SETTINGS_DATABASE_PASSWORD",
          "options": {
            "encrypt": false,
            "trustServerCertificate": true
          }
        }
      }
    },
    "storage": {
      "enabled": true,
      "defaultProvider": "local",
      "providers": {
        "local": {
          "driver": "local",
          "rootPath": "./storage"
        }
      }
    },
    "notifications": {
      "enabled": true,
      "defaultChannel": "email",
      "channels": {
        "email": {
          "provider": "smtp",
          "host": "localhost",
          "port": 1025,
          "secure": false,
          "username": "SETTINGS_NOTIFICATIONS_EMAIL_USERNAME",
          "password": "SETTINGS_NOTIFICATIONS_EMAIL_PASSWORD",
          "from": {
            "name": "User Name",
            "email": "address@domain.com"
          }
        }
      }
    }
  }
}
