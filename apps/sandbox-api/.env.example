# =================================================================================
# Sandbox API for Developers
# =================================================================================
# Ambiente de desarrollo de la app
# Copyright by CLAIN México, S.A. de C.V.
# =================================================================================
#
# Este archivo es una plantilla segura para configurar el ambiente local.
#
# Uso:
#   cp .env.example .env
#
# IMPORTANTE:
# - Los valores incluidos aquí son solo para desarrollo local.
# - No usar estos passwords en producción.
# =================================================================================

# =================================================================================
# Security
# =================================================================================

# Llave secreta usada para firmar/verificar tokens JWT.
SETTINGS_SECURITY_JWT_SECRET=


# =================================================================================
# License
# =================================================================================

# Llave de licencia de la app.
SETTINGS_LICENSE_KEY=


# =================================================================================
# DataBase
# =================================================================================

# Nombre de la base de datos.
SETTINGS_DATABASE_NAME=
# Usuario de conexión a la base de datos.
SETTINGS_DATABASE_USERNAME=
# Contraseña de conexión a la base de datos.
SETTINGS_DATABASE_PASSWORD=


# =================================================================================
# Notifications
# =================================================================================

# Usuario del proveedor SMTP.
SETTINGS_NOTIFICATIONS_EMAIL_USERNAME=
# Contraseña del proveedor SMTP.
SETTINGS_NOTIFICATIONS_EMAIL_PASSWORD=
