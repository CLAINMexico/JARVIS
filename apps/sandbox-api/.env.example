# =================================================================================
# J.A.R.V.I.S. | Environment Example
# =================================================================================
#
# Este archivo sirve como plantilla de variables de entorno para una aplicación
# construida sobre J.A.R.V.I.S.
#
# No debe contener secretos reales.
# Los valores reales deben vivir en el archivo .env local de cada ambiente.
#

# =================================================================================
# App
# =================================================================================

# Llave de licencia de la aplicación.
SETTINGS_LICENSE_KEY=


# =================================================================================
# Security
# =================================================================================

# Llave secreta usada para firmar y verificar tokens JWT.
SETTINGS_SECURITY_JWT_SECRET=


# =================================================================================
# Database
# =================================================================================

# Nombre de la base de datos.
SETTINGS_DATABASE_NAME=

# Usuario de conexión a la base de datos.
SETTINGS_DATABASE_USERNAME=

# Contraseña de conexión a la base de datos.
SETTINGS_DATABASE_PASSWORD=


# =================================================================================
# Notifications
# =================================================================================

# Usuario del proveedor SMTP.
SETTINGS_NOTIFICATIONS_EMAIL_USERNAME=

# Contraseña del proveedor SMTP.
SETTINGS_NOTIFICATIONS_EMAIL_PASSWORD=
