# =================================================================================
# J.A.R.V.I.S. | Sandbox-API HTTP Tests
# =================================================================================
#
# Archivo de pruebas para VS Code REST Client.
#
# Objetivo:
# - Validar rutas base de Sandbox-API.
# - Validar respuestas estándar de @jarvis/http.
# - Validar firma y verificación JWT de @jarvis/security.
# - Validar Bearer Auth universal usando rutas protegidas.
# - Validar Authorization por roles y permisos usando rutas protegidas.
# - Validar Policies usando reglas definidas por Sandbox-API y evaluadas por @jarvis/security.
#
# Flujo recomendado:
# 1. Ejecutar App | Health.
# 2. Ejecutar JWT | Sign access token.
# 3. Ejecutar JWT | Sign refresh token.
# 4. Ejecutar JWT | Sign service token.
# 5. Ejecutar Bearer Auth | Protected route with access token.
# 6. Ejecutar Bearer Auth | Me with access token.
# 7. Ejecutar Authorization | Role admin allowed.
# 8. Ejecutar Authorization | Permission security.auth.test allowed.
# 9. Ejecutar Authorization | Admin role and permission allowed.
# 10. Ejecutar Policy | Role admin allowed.
# 11. Ejecutar Policy | Permission security.auth.test allowed.
# 12. Ejecutar Policy | Admin role and permission allowed.
# 13. Ejecutar JWT | Sign access token without roles.
# 14. Ejecutar JWT | Sign access token without permissions.
# 15. Ejecutar JWT | Sign access token guest.
# 16. Ejecutar los casos forbidden de Authorization.
# 17. Ejecutar los casos forbidden de Policies.
# 18. Ejecutar los casos de error JWT y Bearer Auth.
#
# Nota:
# Los requests con # @name guardan su respuesta para reutilizar tokens.
# Ejemplo:
# {{signAccessToken.response.body.data.token}}
#
# =================================================================================


# =================================================================================
# Variables
# =================================================================================

@host = https://localhost:3000
@contentType = application/json


# =================================================================================
# App | Sandbox-API
# =================================================================================
#
# Estas pruebas validan que Sandbox-API este viva y que el runtime de J.A.R.V.I.S.
# responda correctamente desde sus rutas base.
#
# =================================================================================

### App | Root
# Valida la ruta principal de Sandbox-API.
# Debe responder informacion general de la aplicacion y rutas disponibles.
GET {{host}}/


### App | Health
# Valida que la API este arriba.
# Usalo como primera prueba despues de arrancar el servidor.
GET {{host}}/health


### App | Info
# Valida la informacion normalizada del runtime.
# Debe incluir app, server, status, timeZone y datos generales de J.A.R.V.I.S.
GET {{host}}/info


### App | Modules
# Valida los modulos vivos registrados dentro de @jarvis/core.
# No representa packages fisicos, sino runtimeModules registrados.
GET {{host}}/modules


# =================================================================================
# HTTP | @jarvis/http
# =================================================================================

### HTTP | Test success response
GET {{host}}/http/success


### HTTP | Test error response
GET {{host}}/http/error


# =================================================================================
# Security | @jarvis/security | JWT - Access Token
# =================================================================================
#
# Access token:
# - Representa un token para consumir rutas protegidas.
# - Es el token permitido para /security/protected y /security/me.
# - Tambien se usa para probar Authorization y Policies por roles y permisos.
#
# Este token principal incluye:
# - role: admin
# - permission: security.auth.test
#
# =================================================================================

### JWT | Sign access token
# @name signAccessToken
POST {{host}}/security/jwt/sign
Content-Type: {{contentType}}

{
  "subject": "user-001",
  "tokenType": "access",
  "sessionId": "session-001",
  "tenantId": "tenant-001",
  "roles": [
    "admin"
  ],
  "permissions": [
    "security.jwt.test",
    "security.auth.test"
  ],
  "metadata": {
    "source": "sandbox-api.http"
  }
}


### JWT | Verify access token
POST {{host}}/security/jwt/verify
Content-Type: {{contentType}}

{
  "token": "{{signAccessToken.response.body.data.token}}"
}


# =================================================================================
# Security | @jarvis/security | JWT - Refresh Token
# =================================================================================

### JWT | Sign refresh token
# @name signRefreshToken
POST {{host}}/security/jwt/sign
Content-Type: {{contentType}}

{
  "subject": "user-001",
  "tokenType": "refresh",
  "sessionId": "session-001",
  "metadata": {
    "source": "sandbox-api.http"
  }
}


### JWT | Verify refresh token
POST {{host}}/security/jwt/verify
Content-Type: {{contentType}}

{
  "token": "{{signRefreshToken.response.body.data.token}}"
}


# =================================================================================
# Security | @jarvis/security | JWT - Service Token
# =================================================================================

### JWT | Sign service token
# @name signServiceToken
POST {{host}}/security/jwt/sign
Content-Type: {{contentType}}

{
  "subject": "service-sandbox-api",
  "tokenType": "service",
  "permissions": [
    "internal.read",
    "internal.health"
  ],
  "metadata": {
    "source": "sandbox-api.http",
    "service": "Sandbox-API"
  }
}


### JWT | Verify service token
POST {{host}}/security/jwt/verify
Content-Type: {{contentType}}

{
  "token": "{{signServiceToken.response.body.data.token}}"
}


# =================================================================================
# Security | @jarvis/security | JWT - Authorization and Policy Test Tokens
# =================================================================================
#
# Estos tokens se usan para validar casos 403 de Authorization y Policies.
#
# Todos son access tokens validos, pero no contienen los roles o permisos
# necesarios para consumir rutas protegidas por autorizacion o policies.
#
# =================================================================================

### JWT | Sign access token without roles
# @name signAccessTokenWithoutRoles
POST {{host}}/security/jwt/sign
Content-Type: {{contentType}}

{
  "subject": "user-no-roles",
  "tokenType": "access",
  "sessionId": "session-no-roles",
  "permissions": [
    "security.auth.test"
  ],
  "metadata": {
    "source": "sandbox-api.http",
    "case": "without-roles"
  }
}


### JWT | Sign access token without permissions
# @name signAccessTokenWithoutPermissions
POST {{host}}/security/jwt/sign
Content-Type: {{contentType}}

{
  "subject": "user-no-permissions",
  "tokenType": "access",
  "sessionId": "session-no-permissions",
  "roles": [
    "admin"
  ],
  "metadata": {
    "source": "sandbox-api.http",
    "case": "without-permissions"
  }
}


### JWT | Sign access token guest
# @name signAccessTokenGuest
POST {{host}}/security/jwt/sign
Content-Type: {{contentType}}

{
  "subject": "user-guest",
  "tokenType": "access",
  "sessionId": "session-guest",
  "roles": [
    "guest"
  ],
  "permissions": [
    "security.guest.read"
  ],
  "metadata": {
    "source": "sandbox-api.http",
    "case": "guest"
  }
}


# =================================================================================
# Security | @jarvis/security | JWT - Error cases
# =================================================================================

### JWT | Verify invalid token
POST {{host}}/security/jwt/verify
Content-Type: {{contentType}}

{
  "token": "token-invalido"
}


### JWT | Verify missing token
POST {{host}}/security/jwt/verify
Content-Type: {{contentType}}

{
  "token": ""
}


### JWT | Sign invalid body
POST {{host}}/security/jwt/sign
Content-Type: {{contentType}}

[]


### JWT | Sign missing tokenType
POST {{host}}/security/jwt/sign
Content-Type: {{contentType}}

{
  "subject": "user-001"
}


# =================================================================================
# Security | @jarvis/security | Bearer Auth - Success cases
# =================================================================================

### Bearer Auth | Protected route with access token
GET {{host}}/security/protected
Authorization: Bearer {{signAccessToken.response.body.data.token}}


### Bearer Auth | Me with access token
GET {{host}}/security/me
Authorization: Bearer {{signAccessToken.response.body.data.token}}


# =================================================================================
# Security | @jarvis/security | Bearer Auth - Error cases
# =================================================================================

### Bearer Auth | Missing Authorization header
GET {{host}}/security/protected


### Bearer Auth | Invalid Authorization header
GET {{host}}/security/protected
Authorization: Basic token-invalido


### Bearer Auth | Bearer without token
GET {{host}}/security/protected
Authorization: Bearer


### Bearer Auth | Invalid Bearer token
GET {{host}}/security/protected
Authorization: Bearer token-invalido


### Bearer Auth | Refresh token forbidden
GET {{host}}/security/protected
Authorization: Bearer {{signRefreshToken.response.body.data.token}}


### Bearer Auth | Service token forbidden
GET {{host}}/security/protected
Authorization: Bearer {{signServiceToken.response.body.data.token}}


# =================================================================================
# Security | @jarvis/security | Authorization - Success cases
# =================================================================================

### Authorization | Role admin allowed
# Esperado:
# - 200 OK
# - Rol autorizado correctamente.
# - Log: security.authorization.role.success
GET {{host}}/security/authorization/role
Authorization: Bearer {{signAccessToken.response.body.data.token}}


### Authorization | Permission security.auth.test allowed
# Esperado:
# - 200 OK
# - Permiso autorizado correctamente.
# - Log: security.authorization.permission.success
GET {{host}}/security/authorization/permission
Authorization: Bearer {{signAccessToken.response.body.data.token}}


### Authorization | Admin role and permission allowed
# Esperado:
# - 200 OK
# - Rol y permiso autorizados correctamente.
# - Log: security.authorization.success
GET {{host}}/security/authorization/admin
Authorization: Bearer {{signAccessToken.response.body.data.token}}


# =================================================================================
# Security | @jarvis/security | Authorization - Forbidden cases
# =================================================================================

### Authorization | Role admin forbidden
# Esperado:
# - 403 FORBIDDEN
# - Roles o permisos insuficientes para esta operacion.
# - Log: security.authorization.role.failed
GET {{host}}/security/authorization/role
Authorization: Bearer {{signAccessTokenWithoutRoles.response.body.data.token}}


### Authorization | Permission security.auth.test forbidden
# Esperado:
# - 403 FORBIDDEN
# - Roles o permisos insuficientes para esta operacion.
# - Log: security.authorization.permission.failed
GET {{host}}/security/authorization/permission
Authorization: Bearer {{signAccessTokenWithoutPermissions.response.body.data.token}}


### Authorization | Admin forbidden for guest
# Esperado:
# - 403 FORBIDDEN
# - Roles o permisos insuficientes para esta operacion.
# - Log: security.authorization.failed
GET {{host}}/security/authorization/admin
Authorization: Bearer {{signAccessTokenGuest.response.body.data.token}}


# =================================================================================
# Security | @jarvis/security | Policies - Success cases
# =================================================================================
#
# Estas pruebas validan el Policy engine universal.
#
# Importante:
# - Las policies concretas pertenecen a Sandbox-API.
# - @jarvis/security solo evalua si el payload autenticado cumple la policy.
#
# Requieren ejecutar antes:
# - JWT | Sign access token
#
# El access token principal debe tener:
# - role: admin
# - permission: security.auth.test
#
# =================================================================================

### Policy | Role admin allowed
# Esperado:
# - 200 OK
# - Policy de rol autorizada correctamente.
# - Log: security.policy.role.success
GET {{host}}/security/policies/role
Authorization: Bearer {{signAccessToken.response.body.data.token}}


### Policy | Permission security.auth.test allowed
# Esperado:
# - 200 OK
# - Policy de permiso autorizada correctamente.
# - Log: security.policy.permission.success
GET {{host}}/security/policies/permission
Authorization: Bearer {{signAccessToken.response.body.data.token}}


### Policy | Admin role and permission allowed
# Esperado:
# - 200 OK
# - Policy autorizada correctamente.
# - Log: security.policy.success
GET {{host}}/security/policies/admin
Authorization: Bearer {{signAccessToken.response.body.data.token}}


# =================================================================================
# Security | @jarvis/security | Policies - Forbidden cases
# =================================================================================
#
# Estas pruebas validan errores 403 cuando el token es valido,
# pero no cumple con la policy definida por Sandbox-API.
#
# Importante:
# Estos casos prueban policies, no autenticacion.
# Por eso el JWT debe ser valido y de tipo access.
#
# =================================================================================

### Policy | Role admin forbidden
# Esperado:
# - 403 FORBIDDEN
# - Policy no autorizada para esta operacion.
# - Log: security.policy.role.failed
# - Log interno: security.policy.forbidden
GET {{host}}/security/policies/role
Authorization: Bearer {{signAccessTokenWithoutRoles.response.body.data.token}}


### Policy | Permission security.auth.test forbidden
# Esperado:
# - 403 FORBIDDEN
# - Policy no autorizada para esta operacion.
# - Log: security.policy.permission.failed
# - Log interno: security.policy.forbidden
GET {{host}}/security/policies/permission
Authorization: Bearer {{signAccessTokenWithoutPermissions.response.body.data.token}}


### Policy | Admin forbidden for guest
# Esperado:
# - 403 FORBIDDEN
# - Policy no autorizada para esta operacion.
# - Log: security.policy.failed
# - Log interno: security.policy.forbidden
GET {{host}}/security/policies/admin
Authorization: Bearer {{signAccessTokenGuest.response.body.data.token}}
