# =================================================================================
# Dependencies
# =================================================================================

# Dependencias instaladas localmente por Node.js / pnpm.
node_modules

# Store local de pnpm cuando se genera dentro del proyecto.
.pnpm-store


# =================================================================================
# Build outputs
# =================================================================================

# Salidas de compilación generadas por TypeScript, bundlers o herramientas futuras.
dist
build

# Cache de TurboRepo si se integra o ejecuta en el monorepo.
.turbo


# =================================================================================
# Environment files
# =================================================================================

# Variables de entorno locales.
# Estos archivos pueden contener secretos, credenciales o valores sensibles.
.env
.env.local
.env.*.local

# Configuración local real de J.A.R.V.I.S.
# El repo debe versionar archivos de ejemplo, no settings.json reales.
settings.json


# =================================================================================
# Operating system files
# =================================================================================

# Archivos generados automáticamente por macOS.
.DS_Store


# =================================================================================
# Test and coverage outputs
# =================================================================================

# Reportes de cobertura generados por herramientas de testing.
coverage


# =================================================================================
# VS Code
# =================================================================================

# Ignora configuración local de VS Code.
.vscode/*

# Permite versionar recomendaciones de extensiones del proyecto.
!.vscode/extensions.json

# Permite versionar configuración compartida del workspace.
!.vscode/settings.json


# =================================================================================
# Logs
# =================================================================================

# Directorio local de bitácoras generado por @jarvis/logger.
logs

# Archivos sueltos de log.
*.log


# =================================================================================
# Local certificates
# =================================================================================

# Certificados y llaves locales para pruebas HTTPS.
#
# Estos archivos no deben publicarse porque pueden contener llaves privadas
# o certificados usados por un entorno local específico.
#
# Cada desarrollador debe generar sus propios certificados locales siguiendo
# la documentación del sandbox.
apps/sandbox-api/certs/*.key
apps/sandbox-api/certs/*.crt
apps/sandbox-api/certs/*.pem
apps/sandbox-api/certs/*.p12
apps/sandbox-api/certs/*.pfx

# Mantiene versionable la carpeta certs sin publicar certificados reales.
!apps/sandbox-api/certs/.gitkeep
