{
  "name": "@jarvis/config",
  "version": "1.0.0",
  "private": true,
  "description": "Config | Paquete principal para cargar, normalizar y exponer configuración para aplicaciones que usen el runtime de J.A.R.V.I.S.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@jarvis/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
